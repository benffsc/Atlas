{
  "name": "@atlas/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:workflow": "playwright test --grep @workflow",
    "test:e2e:data": "playwright test --grep @data-quality",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:e2e:visual:update": "playwright test e2e/visual-regression.spec.ts --update-snapshots",
    "test:e2e:ci": "CLEANUP_TEST_DATA=1 playwright test",
    "test:e2e:tippy": "INCLUDE_REAL_API=1 playwright test --grep @real-api",
    "test:e2e:tippy:archive": "INCLUDE_REAL_API=1 playwright test --grep @real-api --reporter=json,html 2>&1 | tee test-results/tippy-archive/tippy-run-$(date +%Y-%m-%d-%H%M).json",
    "test:e2e:vision": "INCLUDE_VISION_API=1 playwright test --grep @vision-api",
    "test:e2e:archive": "playwright test --grep-invert '@real-api|@vision-api' --reporter=json,html 2>&1 | tee test-results/archive/run-$(date +%Y-%m-%d-%H%M).json",
    "test": "vitest run && playwright test --grep-invert '@real-api|@vision-api'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-leaflet/core": "^2.1.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-table": "^8.21.3",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.3.1",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "next": "^16.1.6",
    "pg": "^8.19.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "resend": "^6.9.3",
    "supercluster": "^8.0.1",
    "swr": "^2.4.1",
    "use-supercluster": "^1.2.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "happy-dom": "^20.8.4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
